<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
<style>
  /* ── RESET & BASE ── */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg:       #f7f5f2;
    --surface:  #ffffff;
    --ink:      #1a1814;
    --ink2:     #6b6860;
    --ink3:     #b0ada8;
    --border:   rgba(26,24,20,0.10);
    --border2:  rgba(26,24,20,0.22);
    --radius:   10px;
    --speed:    0.18s;
    --font:     'DM Sans', sans-serif;
    --font2:    'Syne', sans-serif;
  }

  body { font-family: var(--font); background: var(--bg); }

  /* ── HEADER ── */
  .layout-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(247,245,242,0.92);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-bottom: 1px solid var(--border);
    height: 85px;
  }

  .layout-header > .container-fluid {
    height: 100%;
    padding-left: 32px;
    padding-right: 32px;
  }
  .layout-header > .container-fluid > .row { height: 100%; }

  /* logo */
  .header-logo {
    font-family: var(--font2);
    font-size: 35px;
    font-weight: 600;
    letter-spacing: 0.14em;
    color: var(--ink);
    text-decoration: none;
    display: inline-block;
  }

  /* nav */
  .header-menu {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .header-menu-item {
    font-size: 20px;
    color: var(--ink2);
    text-decoration: none;
    padding: 7px 13px;
    border-radius: 8px;
    transition: background var(--speed), color var(--speed);
    white-space: nowrap;
  }

  .header-menu-item:hover { background: rgba(26,24,20,0.06); color: var(--ink); }

  /* search */
  .header-search {
    display: flex;
    align-items: center;
    gap: 0;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    transition: border-color var(--speed), box-shadow var(--speed);
    width: 100%;
    max-width: 280px;
  }

  .header-search:focus-within {
    border-color: var(--border2);
    box-shadow: 0 0 0 3px rgba(26,24,20,0.06);
  }

  .header-search-input {
    flex: 1;
    min-width: 0;
    border: none;
    outline: none;
    background: transparent;
    font-family: var(--font);
    font-size: 16px;
    color: var(--ink);
    padding: 10px 13px;
  }

  .header-search-input::placeholder { color: var(--ink3); }

  .header-search-btn {
    flex-shrink: 0;
    border: none;
    border-left: 1px solid var(--border);
    background: transparent;
    font-family: var(--font);
    font-size: 16px;
    font-weight: 500;
    color: var(--ink2);
    padding: 10px 15px;
    cursor: pointer;
    transition: background var(--speed), color var(--speed);
    white-space: nowrap;
  }

  .header-search-btn:hover { background: rgba(26,24,20,0.04); color: var(--ink); }

  /* action area */
  .header-action {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    padding-right: 4px;
  }

  /* ── LOGIN BUTTON ── */
  .header-login-btn {
    display: inline-block;
    font-family: var(--font);
    font-size: 15px;
    font-weight: 500;
    padding: 9px 22px;
    border-radius: var(--radius);
    border: 1px solid var(--border2);
    background: var(--surface);
    color: var(--ink);
    text-decoration: none;
    cursor: pointer;
    transition: background var(--speed), border-color var(--speed);
  }

  .header-login-btn:hover { background: rgba(26,24,20,0.05); }

  /* ── USER DROPDOWN ── */
  .user-dropdown {
    position: relative;
    display: inline-block;
  }

  .user-icon {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    border: 1px solid var(--border2);
    background: var(--surface);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 17px;
    cursor: pointer;
    transition: border-color var(--speed), box-shadow var(--speed);
    user-select: none;
  }

  .user-icon:hover {
    border-color: rgba(26,24,20,0.4);
    box-shadow: 0 0 0 3px rgba(26,24,20,0.06);
  }

  .user-menu {
    display: none;
    position: absolute;
    top: calc(100% + 10px);
    right: 0;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    box-shadow: 0 12px 40px rgba(26,24,20,0.12);
    min-width: 190px;
    overflow: hidden;
    z-index: 200;
    animation: dropIn 0.16s cubic-bezier(0.34,1.26,0.64,1);
  }

  @keyframes dropIn {
    from { opacity:0; transform: translateY(-6px) scale(0.97); }
    to   { opacity:1; transform: translateY(0)   scale(1); }
  }

  .user-dropdown:hover .user-menu,
  .user-dropdown.open .user-menu { display: block; }

  .user-menu a {
    width: 250px;
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 11px 16px;
    font-size: 18px;
    color: var(--ink2);
    text-decoration: none;
    transition: background var(--speed), color var(--speed);
  }

  .user-menu a:hover { background: rgba(26,24,20,0.04); color: var(--ink); }

  .user-menu a:not(:last-child) { border-bottom: 1px solid var(--border); }

  .user-menu a:last-child { color: #b94040; }
  .user-menu a:last-child:hover { background: rgba(185,64,64,0.06); color: #8c2a2a; }

  /* ── OVERLAY ── */
  .form-login,
  .form-register {
    display: none;
    position: fixed;
    inset: 0;
    margin-top: 20%;
    background: rgba(26,24,20,0.40);
    backdrop-filter: blur(5px);
    -webkit-backdrop-filter: blur(5px);
    z-index: 500;
    align-items: center;
    justify-content: center;
  }

  .form-login.active,
  .form-register.active { display: flex; }

  /* modal box */
  .form-login-main,
  .form-register-main {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 18px;
    width: 600px;
    padding: 2rem;
    position: relative;
    box-shadow: 0 24px 64px rgba(26,24,20,0.14);
    animation: slideUp 0.2s cubic-bezier(0.34,1.26,0.64,1);
  }

  @keyframes slideUp {
    from { opacity:0; transform: translateY(18px); }
    to   { opacity:1; transform: translateY(0); }
  }
  /* close */
  .form-login-close,
  .form-register-close {
    position: absolute;
    top: 1rem;
    right: 1.1rem;
    font-size: 50px;
    line-height: 1;
    color: var(--ink3);
    cursor: pointer;
    transition: color var(--speed);
  }

  .form-login-close:hover,
  .form-register-close:hover { color: var(--ink); }

  /* title */
  .form-login-title,
  .form-register-title {
    font-family: var(--font2);
    font-size: 20px;
    font-weight: 600;
    color: var(--ink);
    margin-bottom: 1.5rem;
  }

  /* field group */
  .form-login-group,
  .form-register-group { margin-bottom: 1rem; }

  .form-login-group label,
  .form-register-group label {
    display: block;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--ink2);
    margin-bottom: 6px;
    margin-top: 10px;
  }

  .form-login-group label:first-child,
  .form-register-group label:first-child { margin-top: 0; }

  .form-login-group input,
  .form-login-group select,
  .form-register-group input,
  .form-register-group select {
    width: 100%;
    padding: 10px 13px;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg);
    font-family: var(--font);
    font-size: 14px;
    color: var(--ink);
    outline: none;
    appearance: none;
    transition: border-color var(--speed), box-shadow var(--speed), background var(--speed);
  }

  .form-login-group input:focus,
  .form-login-group select:focus,
  .form-register-group input:focus,
  .form-register-group select:focus {
    border-color: var(--border2);
    box-shadow: 0 0 0 3px rgba(26,24,20,0.07);
    background: #fff;
  }

  /* submit */
  .form-login-submit,
  .form-register-submit {
    width: 100%;
    padding: 11px;
    margin-top: 0.5rem;
    background: var(--ink);
    color: var(--bg);
    border: none;
    border-radius: var(--radius);
    font-family: var(--font);
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    transition: opacity var(--speed), transform 0.1s;
  }

  .form-login-submit:hover,
  .form-register-submit:hover { opacity: 0.82; }
  .form-login-submit:active,
  .form-register-submit:active { transform: scale(0.99); }

  /* switch link */
  .form-login-register-text {
    margin-top: 1rem;
    text-align: center;
    font-size: 13px;
    color: var(--ink2);
  }

  .form-login-register-text a {
    color: var(--ink);
    font-weight: 500;
    text-decoration: underline;
    cursor: pointer;
  }
</style>

<!-- Google Fonts -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@600&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">

<header class="layout-header">
  <div class="container-fluid">
    <div class="row align-items-center">

      <!-- logo -->
      <div class="col-lg-2">
        <a href="" class="header-logo">UNICODE</a>
      </div>

      <!-- menu -->
      <div class="col-lg-5">
        <nav class="header-menu">
          <a href="" class="header-menu-item">Trang chủ</a>
          <a href="" class="header-menu-item">Giỏ hàng</a>
          <a href="" class="header-menu-item">Danh mục</a>
          <a href="" class="header-menu-item">Khuyến mãi</a>
          <a href="" class="header-menu-item">Liên hệ</a>
        </nav>
      </div>

      <!-- search -->
      <div class="col-lg-3">
        <form class="header-search">
          <input
            type="text"
            class="header-search-input"
            placeholder="Tra cứu sản phẩm..."
          />
          <button type="button" class="header-search-btn">Tìm</button>
        </form>
      </div>

      <!-- action -->
      <div class="col-lg-2">
        <div class="header-action">
          {{#if user}}

            <!-- ICON USER + DROPDOWN -->
            <div class="user-dropdown" id="userDropdown">
<div class="user-icon" id="userIconBtn">
  <i class="fa-solid fa-bars" ></i>
</div>
              <div class="user-menu">
                <a href="/user/profile">
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
                  Thông tin cá nhân
                </a>
                <a href="/cart">
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
                  Giỏ hàng
                </a>
                <a href="/order">
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="1"/><path d="M9 12h6M9 16h4"/></svg>
                  Đơn hàng
                </a>
                <a href="/user/logout">
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                  Đăng xuất
                </a>
              </div>
            </div>

          {{else}}

            <a href="" class="header-login-btn" id="openLogin">Đăng nhập</a>

          {{/if}}
        </div>
      </div>

    </div>
  </div>

  <!-- FORM LOGIN -->
  <div class="form-login" id="formLogin">
    <div class="form-login-main">

      <span class="form-login-close">&times;</span>

      <h2 class="form-login-title">Đăng nhập</h2>

      <form method="post" action="/user/authLogin">
        <div class="form-login-group">
          <label>Tên đăng nhập</label>
          <input type="text" placeholder="Nhập tên đăng nhập" required name="tenDangNhap" />
        </div>

        <div class="form-login-group">
          <label>Mật khẩu</label>
          <input type="password" placeholder="Nhập mật khẩu" required name="matKhau" />
        </div>

        <button type="submit" class="form-login-submit">Đăng nhập</button>
      </form>

      <p class="form-login-register-text">
        Chưa có tài khoản?
        <a class="open-register">Đăng ký</a>
      </p>

    </div>
  </div>

  <!-- FORM REGISTER -->
  <div class="form-register" id="formRegister">
    <div class="form-register-main">

      <span class="form-register-close">&times;</span>

      <h2 class="form-register-title">Đăng ký</h2>

      <form method="post" action="/user/dangKy">

        <div class="form-register-group">
          <label>Tên người dùng</label>
          <input type="text" placeholder="Nhập tên người dùng" name="hoTen" />
        </div>

        <div class="form-register-group">
          <label>Giới tính</label>
          <select name="gioiTinh" required>
            <option value="" disabled selected>-- Chọn giới tính --</option>
            <option value="nam">Nam</option>
            <option value="nu">Nữ</option>
          </select>
        </div>

        <div class="form-register-group">
          <label>Tên đăng nhập</label>
          <input type="text" placeholder="Nhập tên đăng nhập" name="tenDangNhap" />
        </div>

        <div class="form-register-group">
          <label>Mật khẩu</label>
          <input type="password" placeholder="Nhập mật khẩu" name="matKhau" />
          <label>Nhập lại mật khẩu</label>
          <input type="password" placeholder="Xác nhận mật khẩu" name="matKhau2" />
        </div>

        <div class="form-register-group">
          <label>Gmail</label>
          <input type="email" placeholder="Nhập gmail" name="gmail" />
        </div>

        <p class="form-login-register-text">
          Đã có tài khoản?
          <a class="login-btn">Đăng nhập</a>
        </p>

        <button type="submit" class="form-register-submit">Đăng ký</button>

      </form>
    </div>
  </div>


</header>

<script>
  (function () {
    const formLogin    = document.getElementById('formLogin');
    const formRegister = document.getElementById('formRegister');
    const openLogin    = document.getElementById('openLogin');
    const userDropdown = document.getElementById('userDropdown');
    const userIconBtn  = document.getElementById('userIconBtn');

    /* ── helpers ── */
    function showLogin()    { formLogin    && formLogin.classList.add('active');    formRegister && formRegister.classList.remove('active'); }
    function showRegister() { formRegister && formRegister.classList.add('active'); formLogin    && formLogin.classList.remove('active'); }
    function closeAll()     { formLogin    && formLogin.classList.remove('active'); formRegister && formRegister.classList.remove('active'); }

    /* ── open login ── */
    if (openLogin) openLogin.addEventListener('click', function (e) { e.preventDefault(); showLogin(); });

    /* ── close buttons ── */
    document.querySelectorAll('.form-login-close').forEach(function (el) {
      el.addEventListener('click', closeAll);
    });
    document.querySelectorAll('.form-register-close').forEach(function (el) {
      el.addEventListener('click', closeAll);
    });

    /* ── switch: login → register ── */
    document.querySelectorAll('.open-register').forEach(function (el) {
      el.addEventListener('click', function (e) { e.preventDefault(); showRegister(); });
    });

    /* ── switch: register → login ── */
    document.querySelectorAll('.login-btn').forEach(function (el) {
      el.addEventListener('click', function (e) { e.preventDefault(); showLogin(); });
    });

    /* ── close on overlay click ── */
    if (formLogin)    formLogin.addEventListener('click',    function (e) { if (e.target === formLogin)    closeAll(); });
    if (formRegister) formRegister.addEventListener('click', function (e) { if (e.target === formRegister) closeAll(); });

    /* ── Escape key ── */
    document.addEventListener('keydown', function (e) { if (e.key === 'Escape') closeAll(); });

    /* ── user dropdown (click toggle, đóng khi click ngoài) ── */
    if (userIconBtn && userDropdown) {
      userIconBtn.addEventListener('click', function (e) {
        e.stopPropagation();
        userDropdown.classList.toggle('open');
      });

      document.addEventListener('click', function () {
        userDropdown.classList.remove('open');
      });
    }
  })();
</script>
