<link
  rel="stylesheet"
  href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"
/>
<!-- Google Fonts -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link
  href="https://fonts.googleapis.com/css2?family=Syne:wght@600&family=DM+Sans:wght@300;400;500&display=swap"
  rel="stylesheet"
/>
<header class="layout-header">
  <div class="container-fluid">
    <div class="row align-items-center">

      <!-- logo -->
      <div class="col-lg-2">
        <a href="" class="header-logo">UNICODE</a>
      </div>

      <!-- menu -->
      <div class="col-lg-5">
        <nav class="header-menu">
          <a href="/" class="header-menu-item">Trang chủ</a>
          <a href="/cart/index" class="header-menu-item">Giỏ hàng</a>
          <a href="" class="header-menu-item">Danh mục</a>
          <a href="/sale.html" class="header-menu-item">Khuyến mãi</a>
          <a href="/lien-he.html" class="header-menu-item">Liên hệ</a>
        </nav>
      </div>

      <!-- search -->
      <div class="col-lg-3">
        <form class="header-search">
          <input
            type="text"
            class="header-search-input"
            placeholder="Tra cứu sản phẩm..."
          />
          <button type="button" class="header-search-btn">Tìm</button>
        </form>
      </div>

      <!-- action -->
      <div class="col-lg-2">
        <div class="header-action">
          {{#if user}}

            <!-- ICON USER + DROPDOWN -->
            <div class="user-dropdown" id="userDropdown">
              <div class="user-icon" id="userIconBtn">
                <i class="fa-solid fa-bars"></i>
              </div>
              <div class="user-menu">
                <a href="/user/profile">
                  <svg
                    width="15"
                    height="15"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.8"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  ><circle cx="12" cy="8" r="4" /><path
                      d="M4 20c0-4 3.6-7 8-7s8 3 8 7"
                    /></svg>
                  Thông tin cá nhân
                </a>
                <a href="/cart/index">
                  <svg
                    width="15"
                    height="15"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.8"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  ><circle cx="9" cy="21" r="1" /><circle
                      cx="20"
                      cy="21"
                      r="1"
                    /><path
                      d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"
                    /></svg>
                  Giỏ hàng
                </a>
                <a href="/order/index">
                  <svg
                    width="15"
                    height="15"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.8"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  ><path
                      d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2"
                    /><rect x="9" y="3" width="6" height="4" rx="1" /><path
                      d="M9 12h6M9 16h4"
                    /></svg>
                  Đơn hàng
                </a>
                <a href="/user/logout">
                  <svg
                    width="15"
                    height="15"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.8"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  ><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" /><polyline
                      points="16 17 21 12 16 7"
                    /><line x1="21" y1="12" x2="9" y2="12" /></svg>
                  Đăng xuất
                </a>
              </div>
            </div>

          {{else}}

            <a href="" class="header-login-btn" id="openLogin">Đăng nhập</a>

          {{/if}}
        </div>
      </div>

    </div>
  </div>

  <!-- FORM LOGIN -->
  <div class="form-login" id="formLogin">
    <div class="form-login-main">

      <span class="form-login-close">&times;</span>

      <h2 class="form-login-title">Đăng nhập</h2>

      <form method="post" action="/user/authLogin">
        <div class="form-login-group">
          <label>Tên đăng nhập</label>
          <input
            type="text"
            placeholder="Nhập tên đăng nhập"
            required
            name="tenDangNhap"
          />
        </div>

        <div class="form-login-group">
          <label>Mật khẩu</label>
          <input
            type="password"
            placeholder="Nhập mật khẩu"
            required
            name="matKhau"
          />
        </div>

        <button type="submit" class="form-login-submit">Đăng nhập</button>
      </form>

      <p class="form-login-register-text">
        Chưa có tài khoản?
        <a class="open-register">Đăng ký</a>
      </p>

    </div>
  </div>

  <!-- FORM REGISTER -->
  <div class="form-register" id="formRegister">
    <div class="form-register-main">

      <span class="form-register-close">&times;</span>

      <h2 class="form-register-title">Đăng ký</h2>

      <form method="post" action="/user/dangKy">

        <div class="form-register-group">
          <label>Tên người dùng</label>
          <input type="text" placeholder="Nhập tên người dùng" name="hoTen" />
        </div>

        <div class="form-register-group">
          <label>Giới tính</label>
          <select name="gioiTinh" required>
            <option value="" disabled selected>-- Chọn giới tính --</option>
            <option value="nam">Nam</option>
            <option value="nu">Nữ</option>
          </select>
        </div>

        <div class="form-register-group">
          <label>Tên đăng nhập</label>
          <input
            type="text"
            placeholder="Nhập tên đăng nhập"
            name="tenDangNhap"
          />
        </div>

        <div class="form-register-group">
          <label>Mật khẩu</label>
          <input type="password" placeholder="Nhập mật khẩu" name="matKhau" />
          <label>Nhập lại mật khẩu</label>
          <input
            type="password"
            placeholder="Xác nhận mật khẩu"
            name="matKhau2"
          />
        </div>

        <div class="form-register-group">
          <label>Gmail</label>
          <input type="email" placeholder="Nhập gmail" name="gmail" />
        </div>

        <p class="form-login-register-text">
          Đã có tài khoản?
          <a class="login-btn">Đăng nhập</a>
        </p>

        <button type="submit" class="form-register-submit">Đăng ký</button>

      </form>
    </div>
  </div>

</header>

<script>
  (function () { const formLogin = document.getElementById('formLogin'); const
  formRegister = document.getElementById('formRegister'); const openLogin =
  document.getElementById('openLogin'); const userDropdown =
  document.getElementById('userDropdown'); const userIconBtn =
  document.getElementById('userIconBtn'); /* ── helpers ── */ function
  showLogin() { formLogin && formLogin.classList.add('active'); formRegister &&
  formRegister.classList.remove('active'); } function showRegister() {
  formRegister && formRegister.classList.add('active'); formLogin &&
  formLogin.classList.remove('active'); } function closeAll() { formLogin &&
  formLogin.classList.remove('active'); formRegister &&
  formRegister.classList.remove('active'); } /* ── open login ── */ if
  (openLogin) openLogin.addEventListener('click', function (e) {
  e.preventDefault(); showLogin(); }); /* ── close buttons ── */
  document.querySelectorAll('.form-login-close').forEach(function (el) {
  el.addEventListener('click', closeAll); });
  document.querySelectorAll('.form-register-close').forEach(function (el) {
  el.addEventListener('click', closeAll); }); /* ── switch: login → register ──
  */ document.querySelectorAll('.open-register').forEach(function (el) {
  el.addEventListener('click', function (e) { e.preventDefault();
  showRegister(); }); }); /* ── switch: register → login ── */
  document.querySelectorAll('.login-btn').forEach(function (el) {
  el.addEventListener('click', function (e) { e.preventDefault(); showLogin();
  }); }); /* ── close on overlay click ── */ if (formLogin)
  formLogin.addEventListener('click', function (e) { if (e.target === formLogin)
  closeAll(); }); if (formRegister) formRegister.addEventListener('click',
  function (e) { if (e.target === formRegister) closeAll(); }); /* ── Escape key
  ── */ document.addEventListener('keydown', function (e) { if (e.key ===
  'Escape') closeAll(); }); /* ── user dropdown (click toggle, đóng khi click
  ngoài) ── */ if (userIconBtn && userDropdown) {
  userIconBtn.addEventListener('click', function (e) { e.stopPropagation();
  userDropdown.classList.toggle('open'); }); document.addEventListener('click',
  function () { userDropdown.classList.remove('open'); }); } })();
</script>