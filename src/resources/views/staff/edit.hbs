<style>
  /* CẤU HÌNH LAYOUT CONTENT CHUNG */
  .content-container {
    background-color: #f8f9fa; /* Nền xám cực nhẹ giúp form trắng nổi bật */
    min-height: 100vh;
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    box-sizing: border-box;
  }

  .form-card {
    background: #ffffff;
    max-width: 1500px;
    margin: 0 auto;
    padding: 35px;
    border-radius: 12px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
  }

  .form-title {
    margin: 0;
    margin-bottom: 25px;
    font-size: 22px;
    font-weight: 600;
    color: #1a1a1a;
    border-bottom: 2px solid #f1f1f1;
    padding-bottom: 15px;
  }

  /* CHIA LƯỚI BỐ TRÍ FORM (GRID 2 CỘT) */
  .form-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }

  .full-width {
    grid-column: span 2;
  }

  /* ĐỊNH DẠNG CÁC Ô NHẬP LIỆU */
  .form-group {
    display: flex;
    flex-direction: column;
  }

  .form-group label {
    font-size: 14px;
    font-weight: 600;
    color: #4a4a4a;
    margin-bottom: 8px;
  }

  .form-group input, 
  .form-group select {
    padding: 12px 14px;
    font-size: 14px;
    border: 1px solid #dcdcdc;
    border-radius: 6px;
    background-color: #fff;
    color: #333;
    outline: none;
    transition: border-color 0.2s;
    box-sizing: border-box;
    width: 100%;
  }

  .form-group input:focus, 
  .form-group select:focus {
    border-color: #1a1a1a; /* Đổi viền đen mảnh khi focus */
  }

  /* NÚT BẤM MÀU ĐEN (BLACK BUTTON) */
  .form-actions {
    grid-column: span 2;
    margin-top: 30px;
    display: flex;
    justify-content: flex-end;
  }

  .btn-submit {
    background-color: #1a1a1a;
    color: #ffffff;
    border: none;
    padding: 14px 35px;
    font-size: 15px;
    font-weight: 600;
    border-radius: 6px;
    cursor: pointer;
    transition: background-color 0.2s, transform 0.1s;
  }

  .btn-submit:hover {
    background-color: #333333;
  }

  .btn-submit:active {
    transform: scale(0.98);
  }
</style>

<div class="content-container">
  <div class="form-card">
    <h3 class="form-title">Sửa Sản Phẩm Đồng Hồ</h3>

    <form action="/san-pham.html/update/" method="POST">
    <input type="hidden" name="id" value="{{dongho._id}}">
      <div class="form-grid">

        <div class="form-group">
          <label for="tenDongHo">Tên đồng hồ</label>
          <input type="text"
                 id="tenDongHo"
                 name="tenDongHo"
                 value="{{dongho.tenDongHo}}"
                 required>
        </div>

        <div class="form-group">
          <label for="idLoai">Loại đồng hồ</label>
          <select id="idLoai" name="idLoai">

            {{#each loaisp}}
                <option value="{{idLoai}}" {{#ifCond dongho.idLoai idLoai}}selected{{/ifCond}}>{{tenLoai}}</option>
            {{/each}}
            
          </select>
        </div>

        <div class="form-group">
          <label for="giaBan">Giá bán</label>
          <input type="number"
                 id="giaBan"
                 name="giaBan"
                 value="{{dongho.giaBan}}"
                 required>
        </div>

        <div class="form-group">
          <label for="tyLeGiamGia">Tỷ lệ giảm giá (%)</label>
          <input type="number"
                 id="tyLeGiamGia"
                 name="tyLeGiamGia"
                 value="{{dongho.tyLeGiamGia}}"
                 min="0"
                 max="100">
        </div>

        <div class="form-group">
          <label for="soLuong">Số lượng</label>
          <input type="number"
                 id="soLuong"
                 name="soLuong"
                 value="{{dongho.soLuong}}"
                 required>
        </div>

        <div class="form-group">
          <label for="trangThai">Trạng thái</label>
          <select id="trangThai" name="trangThai">
            <option value="Còn hàng" {{#ifCond dongho.trangThai "Còn hàng"}}selected{{/ifCond}}>Còn hàng</option>
            <option value="Hết hàng" {{#ifCond dongho.trangThai "Hết hàng"}}selected{{/ifCond}}>Hết hàng</option>
          </select>
        </div>

        <div class="form-group full-width">
          <label for="anhMoTa">Ảnh mô tả (Link URL)</label>
          <input type="text"
                 id="anhMoTa"
                 name="anhMoTa"
                 value="{{dongho.anhMoTa}}">
        </div>
        <div class="form-actions">
          <button type="submit" class="btn-submit">
            Cập nhật
          </button>
        </div>
      </div>
    </form>
  </div>
</div>