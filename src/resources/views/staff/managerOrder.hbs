<link
  href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap"
  rel="stylesheet"
/>

<style>
  body {
    font-family: "Inter", sans-serif;
    background: #f5f5f5;
  }

  /* container */
  .order-container {
    padding: 30px;
  }

  /* title */
  .page-title {
    font-size: 20px;
    font-weight: 600;
    margin-bottom: 20px;
  }

  /* tabs */
  .tabs {
    display: flex;
    gap: 10px;
    margin-bottom: 20px;
    flex-wrap: wrap;
  }

  .tab {
    padding: 10px 14px;
    border-radius: 6px;
    background: #fff;
    border: 1px solid #ddd;
    cursor: pointer;
    font-size: 13px;
    transition: 0.2s;
  }

  .tab:hover {
    border-color: #000;
  }

  .tab.active {
    background: #000;
    color: #fff;
  }

  /* table */
  .table-wrap {
    background: #fff;
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid #ddd;
  }

  table {
    width: 100%;
    border-collapse: collapse;
  }

  th,
  td {
    padding: 12px;
    font-size: 13px;
    border-bottom: 1px solid #eee;
  }

  th {
    background: #fafafa;
    text-align: left;
    font-weight: 600;
    font-size: 12px;
  }

  /* status badge */
  .badge {
    padding: 5px 10px;
    border-radius: 20px;
    font-size: 12px;
  }

  .pending {
    background: #fff3cd;
    color: #856404;
  }
  .shipping {
    background: #cce5ff;
    color: #004085;
  }
  .done {
    background: #d4edda;
    color: #155724;
  }
  .cancel {
    background: #f8d7da;
    color: #721c24;
  }

  /* action */
  .btn {
    padding: 6px 10px;
    border: none;
    border-radius: 4px;
    font-size: 12px;
    cursor: pointer;
  }

  .btn-view {
    background: #000;
    color: #fff;
  }
  .btn-danger {
    background: #dc3545;
    color: #fff;
  }
  .btn-success {
    background: #28a745;
    color: #fff;
  }

  /* filter section */
  .filter {
    margin-bottom: 15px;
    display: flex;
    gap: 10px;
  }

  .filter input {
    padding: 8px;
    border: 1px solid #ddd;
    border-radius: 5px;
    width: 250px;
  }
</style>

<div class="order-container">

  <div class="page-title">Quản lý đơn hàng</div>

  <!-- FILTER -->
  <div class="filter">
    <input type="text" placeholder="Tìm theo tên khách hàng / SĐT..." />
    <button class="btn btn-view">Tìm kiếm</button>
  </div>

  <!-- TABS -->
  <div class="tabs">
    <div class="tab active">Tất cả</div>
    <div class="tab">Chờ xác nhận</div>
    <div class="tab">Đang giao</div>
    <div class="tab">Hoàn thành</div>
    <div class="tab">Đã hủy</div>
  </div>

  <!-- TABLE -->
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Mã đơn</th>
          <th>Khách hàng</th>
          <th>Số điện thoại</th>
          <th>Tổng tiền</th>
          <th>Trạng thái</th>
          <th>Ngày đặt</th>
          <th>Hành động</th>
        </tr>
      </thead>

      <tbody>

        <!-- SAMPLE ROW -->
        <tr>
          <td>#DH001</td>
          <td>Nguyễn Văn A</td>
          <td>0901234567</td>
          <td>12,500,000₫</td>
          <td><span class="badge pending">Chờ xác nhận</span></td>
          <td>19/05/2026</td>
          <td>
            <button class="btn btn-view">Xem</button>
            <button class="btn btn-success">Duyệt</button>
            <button class="btn btn-danger">Hủy</button>
          </td>
        </tr>

        <tr>
          <td>#DH002</td>
          <td>Trần Thị B</td>
          <td>0987654321</td>
          <td>8,900,000₫</td>
          <td><span class="badge shipping">Đang giao</span></td>
          <td>18/05/2026</td>
          <td>
            <button class="btn btn-view">Xem</button>
            <button class="btn btn-success">Hoàn thành</button>
          </td>
        </tr>

        <tr>
          <td>#DH003</td>
          <td>Lê Văn C</td>
          <td>0912345678</td>
          <td>5,200,000₫</td>
          <td><span class="badge done">Hoàn thành</span></td>
          <td>17/05/2026</td>
          <td>
            <button class="btn btn-view">Xem</button>
          </td>
        </tr>

        <tr>
          <td>#DH004</td>
          <td>Phạm Văn D</td>
          <td>0909999999</td>
          <td>3,100,000₫</td>
          <td><span class="badge cancel">Đã hủy</span></td>
          <td>16/05/2026</td>
          <td>
            <button class="btn btn-view">Xem</button>
          </td>
        </tr>

      </tbody>
    </table>
  </div>

</div>