

<div class="pd-grid">

  {{! ── GALLERY ── }}
  <div class="pd-gallery">
    <div class="pd-gallery__main">
      <span class="pd-badge">-{{ketqua.dongho.tyLeGiamGia}}%</span>
      <img
        id="pd-img-main"
        src="{{ketqua.dongho.anhMoTa}}"
        alt="{{ketqua.dongho.tenDongHo}}"
      />
    </div>

    <div class="pd-thumbs">
      {{! Ảnh chính làm thumb đầu tiên }}
      <div
        class="pd-thumb active"
        onclick="pdThumb(this,'{{ketqua.dongho.anhMoTa}}')"
      >
        <img src="{{ketqua.dongho.anhMoTa}}" alt="Ảnh chính" />
      </div>
      {{! Các ảnh phụ }}
      {{#each ketqua.dongho.anhmota}}
        <div class="pd-thumb" onclick="pdThumb(this,'{{this.path}}')">
          <img src="{{this.path}}" alt="Ảnh {{@index}}" />
        </div>
      {{/each}}
    </div>
  </div>

  {{! ── INFO ── }}
  <div class="pd-info">

    <p class="pd-tag">Đồng Hồ Cao Cấp</p>
    <h1 class="pd-name">{{ketqua.dongho.tenDongHo}}</h1>

    <div class="pd-rating">
      <span class="pd-stars">★★★★★</span>
      <span class="pd-rcount">({{ketqua.danhgia.length}} đánh giá)</span>
    </div>

    <div class="pd-price">
      <span class="pd-price__cur">{{ketqua.dongho.giaSauGiam}} ₫</span>
      <span class="pd-price__orig">{{ketqua.dongho.giaBan}} ₫</span>
      <span class="pd-price__pct">-{{ketqua.dongho.tyLeGiamGia}}%</span>
    </div>

    <div class="pd-specs">
      <div class="pd-spec">
        <span class="pd-spec__lbl">Giới tính</span>
        <span class="pd-spec__val">{{ketqua.dongho.thongSo.gioiTinh}}</span>
      </div>
      <div class="pd-spec">
        <span class="pd-spec__lbl">Mặt kính</span>
        <span class="pd-spec__val">{{ketqua.dongho.thongSo.matKinh}}</span>
      </div>
      <div class="pd-spec">
        <span class="pd-spec__lbl">Độ dày</span>
        <span class="pd-spec__val">{{ketqua.dongho.thongSo.doDay}}</span>
      </div>
      <div class="pd-spec">
        <span class="pd-spec__lbl">Chất liệu</span>
        <span class="pd-spec__val">{{ketqua.dongho.thongSo.chatLieu}}</span>
      </div>
      <div class="pd-spec">
        <span class="pd-spec__lbl">Dây đeo</span>
        <span class="pd-spec__val">{{ketqua.dongho.thongSo.dayDeo}}</span>
      </div>
      <div class="pd-spec">
        <span class="pd-spec__lbl">Trạng thái</span>
        <span class="pd-spec__val">{{ketqua.dongho.trangThai}}</span>
      </div>
    </div>

    <hr class="pd-hr" />

    <div class="pd-stock">
      {{#if ketqua.dongho.soLuong}}
        <span class="pd-dot"></span>
        <span>{{ketqua.dongho.trangThai}}
          — còn
          <strong>{{ketqua.dongho.soLuong}}</strong>
          sản phẩm</span>
      {{else}}
        <span class="pd-dot out"></span>
        <span>Hết hàng</span>
      {{/if}}
    </div>

    <form action="" method="post">
      <input type="hidden" name="idDongHo" value="{{ketqua.dongho._id}}" />
      <input type="hidden" name="soLuong" value="{{ketqua.dongho.soLuong}}" />

      <div class="pd-qty-row">
        <span class="pd-qty-lbl">Số lượng</span>
        <div class="pd-qty">
          <button type="button" onclick="pdQty(-1)">−</button>
          <input
            class="pd-qty__n"
            type="number"
            value="1"
            min="1"
            max="{{ketqua.dongho.soLuong}}"
            id="pd-qty"
            name="soLuongMua"
          />
          <button type="button" onclick="pdQty(1)">+</button>
        </div>
      </div>
      <br />
      <div class="pd-actions">
        <button class="pd-btn-cart" formaction="/cart/store.html">Thêm vào giỏ
          hàng</button>
        <button class="pd-btn-buy" formaction="/order/create">🛒 Đặt hàng</button>
      </div>
    </form>

  </div>
</div>

{{! ── TABS ── }}
<div class="pd-tabs">

  <div class="pd-tabs__nav">
    <button class="pd-tab-btn active" onclick="pdTab(this,'pd-t1')">Thông Số</button>
    <button class="pd-tab-btn" onclick="pdTab(this,'pd-t2')">Chính Sách</button>
    <button class="pd-tab-btn" onclick="pdTab(this,'pd-t3')">Đánh Giá</button>
  </div>

  {{! ── TAB 1: THÔNG SỐ + MÔ TẢ ── }}
  <div class="pd-tab-panel active" id="pd-t1">

    <table class="pd-tbl">
      <tr><td>Giới tính</td> <td>{{ketqua.dongho.thongSo.gioiTinh}}</td></tr>
      <tr><td>Mặt kính</td> <td>{{ketqua.dongho.thongSo.matKinh}}</td></tr>
      <tr><td>Độ dày</td> <td>{{ketqua.dongho.thongSo.doDay}}</td></tr>
      <tr><td>Chất liệu</td> <td>{{ketqua.dongho.thongSo.chatLieu}}</td></tr>
      <tr><td>Dây đeo</td> <td>{{ketqua.dongho.thongSo.dayDeo}}</td></tr>
      <tr><td>Giá bán</td> <td>{{ketqua.dongho.giaBan}} ₫</td></tr>
      <tr><td>Còn lại</td> <td>{{ketqua.dongho.soLuong}} sản phẩm</td></tr>
      <tr><td>Tình trạng</td><td>{{ketqua.dongho.trangThai}}</td></tr>
    </table>

    <div class="pd-desc">
      {{#if ketqua.dongho.moTa}}
        <p>{{ketqua.dongho.moTa}}</p>
      {{/if}}
      {{#if ketqua.dongho.videoMoTa}}
        <div class="pd-video-wrap">
          <iframe
            width="100%"
            height="400"
            src="{{ketqua.dongho.videoMoTa}}"
            title="Video mô tả"
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
          >
          </iframe>
        </div>
      {{/if}}
    </div>

  </div>

  {{! ── TAB 2: CHÍNH SÁCH ── }}
  <div class="pd-tab-panel" id="pd-t2">

    <div class="policy-box">
      <h2>Chính sách bảo hành & hậu mãi</h2>
      <p>Tất cả đồng hồ mua tại cửa hàng đều được bảo hành theo chính sách quốc
        tế và tại cửa hàng kể từ ngày mua.</p>
      <p><b>Bảo hành quốc tế:</b> 3 năm theo chính sách hãng.</p>
      <p><b>Bảo hành tại cửa hàng:</b>
        Tổng 5 năm (bao gồm quốc tế) + miễn phí thay pin trọn đời (Quartz).</p>
    </div>

    <div class="policy-box">
      <h2>Điều kiện & trường hợp bảo hành</h2>
      <h4>Được bảo hành khi:</h4>
      <ul>
        <li>Có phiếu bảo hành hoặc biên nhận hợp lệ</li>
        <li>Phiếu còn nguyên vẹn, không tẩy xóa</li>
        <li>Còn trong thời gian bảo hành</li>
      </ul>
      <h4>Không bảo hành khi:</h4>
      <ul>
        <li>Hư hỏng do va đập, bảo quản sai cách</li>
        <li>Vào nước sai tiêu chuẩn chống nước</li>
        <li>Tự ý sửa chữa bên ngoài</li>
      </ul>
    </div>

  </div>

  {{! ── TAB 3: ĐÁNH GIÁ ── }}
  <div class="pd-tab-panel" id="pd-t3">

    {{! Tổng quan }}
    <div class="pd-rev-summary">
      <div class="pd-rev-score">
        <div class="pd-rev-num">{{ketqua.trungBinhSao}}</div>
        <div class="pd-rev-stars">★★★★★</div>
        <div class="pd-rev-total">{{ketqua.danhgia.length}} đánh giá</div>
      </div>
      <div class="pd-bars">
        {{#each ketqua.thongKeSao}}
          <div class="pd-bar-row">
            <span class="pd-bar-lbl">{{this.soSao}}★</span>
            <div class="pd-bar-track">
              <div class="pd-bar-fill" style="width:{{this.phanTram}}%"></div>
            </div>
            <span class="pd-bar-cnt">{{this.soLuong}}</span>
          </div>
        {{/each}}
      </div>
    </div>

    <div class="pd-rev-body">

      {{! Form bình luận }}
      <div class="comment-box">
        <h3>Đăng bình luận</h3>
        <form action="/comment/push" method="post" class="comment-form">
          <input type="hidden" name="idDongHo" value="{{ketqua.dongho._id}}" />

          <div class="form-group">
            <label>Họ tên</label>
            <input
              type="text"
              name="name"
              value="{{user.hoTen}}"
              readonly
              placeholder="Nhập họ tên..."
            />
          </div>

          <div class="form-group">
            <label>Đánh giá</label>
            <select name="soSao">
              <option value="5" selected>★★★★★ — Rất tốt</option>
              <option value="4">★★★★☆ — Tốt</option>
              <option value="3">★★★☆☆ — Bình thường</option>
              <option value="2">★★☆☆☆ — Không hài lòng</option>
              <option value="1">★☆☆☆☆ — Tệ</option>
            </select>
          </div>

          <div class="form-group">
            <label>Nội dung</label>
            <textarea
              name="noiDung"
              rows="4"
              placeholder="Viết bình luận..."
              required
            ></textarea>
          </div>

          <button type="submit">Gửi bình luận</button>
        </form>
      </div>

      {{! Danh sách bình luận }}
      <div class="comment-box">
        <h3>Bình luận ({{ketqua.danhgia.length}})</h3>
        <div id="pd-revlist">
          {{#each ketqua.danhgia}}
            <div class="pd-rev-card">
              <div class="pd-rev-hdr">
                <div>
                  <div class="pd-rev-name">Ẩn danh</div>
                  <div class="pd-rev-date">{{this.ngayDanhGia}}</div>
                </div>
                <span class="pd-rev-stars2">
                  {{#if (eq this.soSao 5)}}★★★★★{{/if}}
                  {{#if (eq this.soSao 4)}}★★★★☆{{/if}}
                  {{#if (eq this.soSao 3)}}★★★☆☆{{/if}}
                  {{#if (eq this.soSao 2)}}★★☆☆☆{{/if}}
                  {{#if (eq this.soSao 1)}}★☆☆☆☆{{/if}}
                </span>
              </div>
              <p class="pd-rev-text">{{this.noiDung}}</p>
            </div>
          {{else}}
            <p class="pd-rev-empty">Chưa có bình luận nào.</p>
          {{/each}}
        </div>
      </div>

    </div>
  </div>

</div>

<script>

  function pdThumb(el, src) { document.getElementById('pd-img-main').src = src;
  document.querySelectorAll('.pd-thumb').forEach(t =>
  t.classList.remove('active')); el.classList.add('active'); } function pdQty(d)
  { const inp = document.getElementById('pd-qty'); let v = parseInt(inp.value) +
  d; if (v < 1) v = 1; if (v > parseInt(inp.max)) v = parseInt(inp.max);
  inp.value = v; } function pdTab(btn, id) {
  document.querySelectorAll('.pd-tab-btn').forEach(b =>
  b.classList.remove('active'));
  document.querySelectorAll('.pd-tab-panel').forEach(p =>
  p.classList.remove('active')); btn.classList.add('active');
  document.getElementById(id).classList.add('active'); }


</script>