
<div class="contact-container">
  <div class="contact-header">
    <h1>Liên hệ với chúng tôi</h1>
    <p>Nếu bạn có bất kỳ câu hỏi hoặc góp ý nào, hãy gửi thông tin cho chúng tôi.</p>
  </div>

  <div class="contact-content">
    <!-- Thông tin liên hệ -->
    <div class="contact-info">
      <div class="info-box">
        <h3>Địa chỉ</h3>
        <p>123 Đường ABC, Hà Nội</p>
      </div>

      <div class="info-box">
        <h3>Số điện thoại</h3>
        <p>0123 456 789</p>
      </div>

      <div class="info-box">
        <h3>Email</h3>
        <p>support@watchshop.com</p>
      </div>

      <div class="info-box">
        <h3>Thời gian làm việc</h3>
        <p>08:00 - 22:00</p>
      </div>
    </div>

 
    <form class="contact-form" action="/contact/send" method="POST">
      <div class="form-group">
        <label>Họ và tên</label>
        <input type="text" name="hoTen" placeholder="Nhập họ tên" required>
      </div>

      <div class="form-group">
        <label>Email</label>
        <input type="email" name="email" placeholder="Nhập email" required>
      </div>

      <div class="form-group">
        <label>Số điện thoại</label>
        <input type="text" name="soDienThoai" placeholder="Nhập số điện thoại">
      </div>

      <div class="form-group">
        <label>Nội dung</label>
        <textarea name="noiDung" rows="6" placeholder="Nhập nội dung liên hệ" required></textarea>
      </div>

      <button type="submit" class="btn-contact">
        Gửi liên hệ
      </button>
    </form>
  </div>
</div>
