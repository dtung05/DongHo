
<div class="sale-page">
  <!-- Banner -->
  <section class="sale-banner">
    <div class="sale-overlay"></div>

    <div class="sale-banner-content">
      <span class="sale-tag">MEGA SALE 2026</span>
      <h1>GIẢM GIÁ ĐỒNG HỒ THÔNG MINH</h1>
      <p>Khám phá những mẫu đồng hồ công nghệ hiện đại với ưu đãi lên đến 50%</p>

      <a href="#sale-product" class="btn-shop-now">
        Mua ngay
      </a>
    </div>
  </section>

  <!-- Flash Sale -->
  <section class="flash-sale">
    <div class="section-header">
      <h2> Flash Sale Công Nghệ</h2>
      <p>Ưu đãi số lượng có hạn</p>
    </div>

    <div class="sale-grid" id="sale-product">
      {{#each dongHo}}
      
      <div class="sale-card"><a href="/san-pham.html/{{_id}}">
        <div class="discount-badge">
          -{{tyLeGiamGia}}%
        </div>

        <div class="sale-image">
          <img src="{{anhMoTa}}" alt="{{tenDongHo}}">
        </div>

        <div class="sale-info">
          <h3>{{tenDongHo}}</h3>

          <div class="price-box">
            <span class="old-price">{{giaBan}}đ</span>
            <span class="new-price">{{giaSauGiam}}đ</span>
          </div>

          <div class="sale-progress">
            <div class="sale-progress-bar"></div>
          </div>

          <button class="btn-buy">
            Mua ngay
          </button>
          </a>
        </div>
      </div>
      {{/each}}
    </div>
  </section>
</div>

