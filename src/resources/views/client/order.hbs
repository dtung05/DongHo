<style>
  .order-container{
    width: 1300px;
    margin: 30px auto;
  }

  .order-tabs{
    display: flex;
    gap: 12px;
    margin-bottom: 24px;
    flex-wrap: wrap;
  }

  .order-tabs a{
    text-decoration: none;
    color: #333;
    background: #f5f5f5;
    padding: 10px 18px;
    border-radius: 999px;
    transition: 0.2s;
    font-weight: 500;
  }

  .order-tabs a:hover{
    background: #111;
    color: white;
  }

  .order-card{
    background: white;
    border-radius: 16px;
    padding: 24px;
    margin-bottom: 24px;
    box-shadow: 0 2px 12px rgba(0,0,0,0.08);
  }

  .order-header{
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 20px;
    padding-bottom: 16px;
    border-bottom: 1px solid #eee;
  }

  .order-id{
    font-size: 15px;
    color: #666;
  }

  .status{
    padding: 8px 14px;
    border-radius: 999px;
    background: #fff3cd;
    color: #856404;
    font-size: 14px;
    font-weight: 600;
  }

  .order-info{
    display: grid;
    grid-template-columns: repeat(2,1fr);
    gap: 10px;
    margin-bottom: 24px;
  }

  .order-info p{
    margin: 0;
    color: #444;
  }

  .product-list{
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }

  .product-item{
    display: flex;
    gap: 16px;
    padding: 16px;
    border-radius: 12px;
    background: #fafafa;
  }

  .product-item img{
    width: 110px;
    height: 110px;
    border-radius: 12px;
    object-fit: cover;
  }

  .product-content{
    flex: 1;
  }

  .product-content h4{
    margin: 0 0 10px;
    font-size: 18px;
  }

  .product-content p{
    margin: 6px 0;
    color: #555;
  }

  .order-footer{
    margin-top: 24px;
    padding-top: 18px;
    border-top: 1px solid #eee;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .total-price{
    font-size: 22px;
    font-weight: bold;
    color: #e53935;
  }

  .btn-cancel{
    border: none;
    background: #e53935;
    color: white;
    padding: 10px 18px;
    border-radius: 10px;
    cursor: pointer;
    transition: 0.2s;
  }

  .btn-cancel:hover{
    opacity: 0.9;
  }

  .empty-order{
    text-align: center;
    padding: 60px 0;
    color: #777;
    font-size: 18px;
  }.order-tabs a.active{
    background: #111;
    color: white;
}
</style>

<div class="order-container">

  <div class="order-tabs">

  <a 
    href="/order/index"
    class="{{#ifCond currentStatus 'all'}}active{{/ifCond}}"
  >
    Tất cả
  </a>

  <a 
    href="/order/index/pending"
    class="{{#ifCond currentStatus 'pending'}}active{{/ifCond}}"
  >
    Chờ xác nhận
  </a>

  <a 
    href="/order/index/shipping"
    class="{{#ifCond currentStatus 'shipping'}}active{{/ifCond}}"
  >
    Đang giao
  </a>

  <a 
    href="/order/index/completed"
    class="{{#ifCond currentStatus 'completed'}}active{{/ifCond}}"
  >
    Hoàn thành
  </a>

  <a 
    href="/order/index/cancel"
    class="{{#ifCond currentStatus 'cancel'}}active{{/ifCond}}"
  >
    Đã hủy
  </a>

</div>

  {{#if orders.length}}

    {{#each orders}}
      <div class="order-card">

        <div class="order-header">
          <div class="order-id">
            Mã đơn: {{_id}}
          </div>

          <div class="status">
            {{trangThai}}
          </div>
        </div>

        <div class="order-info">
          <p><strong>Người nhận:</strong> {{tenNguoiNhan}}</p>
          <p><strong>SĐT:</strong> {{soDienThoai}}</p>
          <p><strong>Địa chỉ:</strong> {{diaChi}}</p>
          <p><strong>Thanh toán:</strong> {{phuongThuc}}</p>
        </div>

        <div class="product-list">

          {{#each dongHo}}
            <div class="product-item">

              <img src="{{img}}" alt="{{tenSanPham}}">

              <div class="product-content">
                <h4>{{tenSanPham}}</h4>

                <p>Số lượng: {{soLuong}}</p>
                 <p>
                  Giảm:
                  {{soTienGiam}}
                </p>
                <p>
                  Thành tiền:
                  {{thanhTien}}
                </p>

               
              </div>

            </div>
          {{/each}}

        </div>

        <div class="order-footer">

          <div class="total-price">
            {{tongTien}}
          </div>

          {{#ifCond trangThai "Chờ xác nhận"}}
           <form action="/order/cancel/" method="POST" class="cancel-form">
  <input type="hidden" name="idDonHang" value="{{_id}}">

  <button type="button" class="btn-cancel">
    Hủy đơn
  </button>
</form>
          {{/ifCond}}

        </div>

      </div>
    {{/each}}
<!-- Confirm Dialog -->
<div id="confirm-overlay"
  style="display:none; position:fixed; inset:0; background:rgba(0,0,0,.45); z-index:999; align-items:center; justify-content:center;">

  <div id="confirm-box"
    style="background:#fff; border-radius:14px; padding:28px 28px 22px; width:340px; max-width:90vw; text-align:center; box-shadow:0 8px 32px rgba(0,0,0,.15);">

    <div style="font-size:17px; font-weight:700; color:#111; margin-bottom:8px;">
      Hủy đơn hàng?
    </div>

    <div style="font-size:14px; color:#666; margin-bottom:22px;" id="confirm-msg">
      Bạn có chắc muốn hủy đơn hàng này không?
    </div>

    <div style="display:flex; gap:10px;">
      <button type="button" id="confirm-cancel"
        style="flex:1; height:42px; border:1.5px solid #ddd; background:#fff; color:#444; border-radius:9px; font-size:14px; font-weight:600; cursor:pointer;">
        Không
      </button>

      <button type="button" id="confirm-ok"
        style="flex:1; height:42px; border:none; background:#e53e3e; color:#fff; border-radius:9px; font-size:14px; font-weight:600; cursor:pointer;">
        Hủy đơn
      </button>
    </div>
  </div>
</div>


  {{else}}

    <div class="empty-order">
      Không có đơn hàng nào
    </div>

  {{/if}}

</div>
<script>
  const cancelBtn = document.querySelector(".btn-cancel");
  const overlay = document.getElementById("confirm-overlay");
  const confirmCancelBtn = document.getElementById("confirm-cancel");
  const confirmOkBtn = document.getElementById("confirm-ok");
  const cancelForm = document.querySelector(".cancel-form");

  // Mở popup
  cancelBtn.addEventListener("click", () => {
    overlay.style.display = "flex";
  });

  // Đóng popup
  confirmCancelBtn.addEventListener("click", () => {
    overlay.style.display = "none";
  });

  // Xác nhận hủy
  confirmOkBtn.addEventListener("click", () => {
    cancelForm.submit();
  });

  // Click nền để đóng
  overlay.addEventListener("click", (e) => {
    if (e.target === overlay) {
      overlay.style.display = "none";
    }
  });
</script>