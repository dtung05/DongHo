

<!-- Google Fonts -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@600&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">

<main class="layout-main">
  <div class="container-fluid" style="padding:0;">

    <!-- ══════════════ HERO SLIDER ══════════════ -->
    <div class="hero" id="hero">
      <div class="hero-track" id="heroTrack">

        <!-- Slide 1 -->
        <div class="hero-slide" style="background: linear-gradient(120deg,#1a1814,#3b2f1e);">
          <img src="https://images.unsplash.com/photo-1523275335684-37898b6baf30?w=1400&q=80" alt="">
          <div class="hero-slide-content">
            <span class="hero-tag">Mới nhất 2025</span>
            <h1 class="hero-title">Đồng hồ cao cấp<br>dành cho bạn</h1>
            <p class="hero-desc">Phong cách sang trọng, độ bền vượt trội — đồng hành cùng mọi khoảnh khắc trong cuộc sống của bạn.</p>
            <a href="#" class="hero-btn">Khám phá ngay</a>
          </div>
        </div>

        <!-- Slide 2 -->
        <div class="hero-slide" style="background: linear-gradient(120deg,#0c2340,#1a4a6e);">
          <img src="https://png.pngtree.com/background/20210710/original/pngtree-black-dynamic-watch-simple-black-banner-picture-image_1032760.jpg" alt="">
          <div class="hero-slide-content">
            <span class="hero-tag">Ưu đãi đặc biệt</span>
            <h1 class="hero-title">Giảm đến 30%<br>đồng hồ thể thao</h1>
            <p class="hero-desc">Bộ sưu tập đồng hồ thể thao chính hãng với nhiều thương hiệu nổi tiếng đang chờ bạn khám phá.</p>
            <a href="#" class="hero-btn">Mua ngay</a>
          </div>
        </div>

        <!-- Slide 3 -->
        <div class="hero-slide" style="background: linear-gradient(120deg,#1c1c1c,#4a3728);">
          <img src="https://images.unsplash.com/photo-1587836374828-4dbafa94cf0e?w=1400&q=80" alt="">
          <div class="hero-slide-content">
            <span class="hero-tag">Bộ sưu tập mới</span>
            <h1 class="hero-title">Đồng hồ cổ điển<br>tinh tế & sang trọng</h1>
            <p class="hero-desc">Vẻ đẹp vượt thời gian từ những thương hiệu danh tiếng thế giới, giờ đây có mặt tại UNICODE.</p>
            <a href="#" class="hero-btn">Xem bộ sưu tập</a>
          </div>
        </div>

      </div>

      <!-- arrows -->
      <button class="hero-arrow prev" id="heroPrev">&#8592;</button>
      <button class="hero-arrow next" id="heroNext">&#8594;</button>

      <!-- dots -->
      <div class="hero-dots" id="heroDots">
        <button class="hero-dot active"></button>
        <button class="hero-dot"></button>
        <button class="hero-dot"></button>
      </div>
    </div>

    <!-- ══════════════ CATEGORIES ══════════════ -->
    <div class="section">
      <div class="cat-grid">
        <a href="/category/luxury" class="cat-card">
          <div class="cat-name">Đồng hồ thể thao</div>
          <div class="cat-count">62 sản phẩm</div>
        </a>
        <a href="/category/sport" class="cat-card">
          <div class="cat-name">Đồng hồ thể thao</div>
          <div class="cat-count">62 sản phẩm</div>
        </a>
        <a href="/category/classic" class="cat-card">
          <div class="cat-name">Đồng hồ cổ điển</div>
          <div class="cat-count">35 sản phẩm</div>
        </a>
        <a href="/category/smart" class="cat-card">
          <div class="cat-name">Đồng hồ thông minh</div>
          <div class="cat-count">27 sản phẩm</div>
        </a>
        <a href="/category/couple" class="cat-card">
          <div class="cat-name">Đồng hồ đôi</div>
          <div class="cat-count">19 sản phẩm</div>
        </a>
      </div>
    </div>

    <!-- ══════════════ PRODUCTS + SIDEBAR ══════════════ -->
    <div class="section">
      <div class="section-head">
        <div>
          <p class="section-label">Sản phẩm</p>
          <h2 class="section-title" style="margin-bottom:0;">Nổi bật hôm nay</h2>
        </div>
        <a href="/products" class="section-more">Xem tất cả →</a>
      </div>

      <div class="product-layout">

        <!-- SIDEBAR DANH MỤC -->
        <aside class="product-sidebar">
          <div class="sidebar-head">
            <p class="sidebar-head-title">Danh mục</p>
          </div>
          <nav class="sidebar-menu">
            <a href="/category/all" class="sidebar-item active">
             
              Tất cả
              <span class="sidebar-count">191</span>
            </a>
            <a href="/category/luxury" class="sidebar-item">
            
              Đồng hồ Luxury
              <span class="sidebar-count">48</span>
            </a>
            <a href="/category/sport" class="sidebar-item">
            
              Thể thao
              <span class="sidebar-count">62</span>
            </a>
            <a href="/category/classic" class="sidebar-item">
            
              Cổ điển
              <span class="sidebar-count">35</span>
            </a>
            <a href="/category/smart" class="sidebar-item">
            
              Thông minh
              <span class="sidebar-count">27</span>
            </a>
            <a href="/category/couple" class="sidebar-item">
             
              Đồng hồ đôi
              <span class="sidebar-count">19</span>
            </a>
          </nav>
        </aside>

        <!-- PRODUCT GRID -->
        <div class="product-wrap">
          <div class="product-grid">
            {{#each dongHo}}
            <a href="/product/{{_id}}" class="product-card">
  <div class="product-image">
    <img src="https://galle.vn/images/products/2026/03/12/resized/ra-ac0q17y30b_1773280118.webp" alt="{{tenDongHo}}">
  </div>

  <div class="product-body">
    <div class="product-name">{{tenDongHo}}</div>
    <div class="product-desc">Trạng thái: {{trangThai}}</div>

    <div class="product-footer">
      <span class="product-price">{{giaBan}}đ</span>
      <span class="product-buy">Mua ngay</span>
    </div>
  </div>
</a>
            {{/each}}
          </div>
        </div>

      </div>
    </div>

  </div>
</main>
